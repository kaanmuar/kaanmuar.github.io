1. Playwright (TypeScript)

import { test, expect } from '@playwright/test';

test.describe('CV Online - Core Functionality', () => {
  test.beforeEach(async ({ page }) => {
    // Navigate to the live CV site before each test
    await page.goto('https://carlosmunoz-cv.example.com');
  });

  test('should verify profile header and professional title', async ({ page }) => {
    // Validate page metadata
    await expect(page).toHaveTitle(/Carlos Andrés Muñoz Ardila - CV/);
    
    // Validate main header injection
    const header = page.locator('h1');
    await expect(header).toHaveText('Carlos Andrés Muñoz Ardila');
    
    // Validate job title using test IDs for resilient selectors
    const role = page.locator('[data-testid="job-title"]');
    await expect(role).toHaveText(/Senior Systems Engineer & QA Lead/i);
  });
});
2. Cypress (JavaScript)

describe('CV Online - Professional Experience Routing', () => {
  beforeEach(() => {
    cy.visit('https://carlosmunoz-cv.example.com');
  });

  it('should navigate to the Experience section and verify recent roles', () => {
    // Intercept potential external API calls for analytics/tracking to prevent flakiness
    cy.intercept('GET', '/api/analytics', { statusCode: 200 }).as('analytics');

    cy.get('nav').contains('Experience').click();
    
    // Validate the timeline renders correctly
    cy.get('.experience-timeline').should('be.visible');
    
    // Verify specific high-impact roles are present in the DOM
    cy.contains('h3', 'QA Studio Lead').should('exist');
    cy.contains('.company-name', 'Team International').should('be.visible');
  });
});
